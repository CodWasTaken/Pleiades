pkgname=pleiades
pkgver=1.0.0
pkgrel=1
pkgdesc='Provider-agnostic terminal AI assistant'
arch=('x86_64' 'aarch64')
url='https://github.com/CodWasTaken/Pleiades'
license=('MIT')
makedepends=('cargo')
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('2879adb71e32a37e35a3b05f70798b201191f8feba2c7c21d873d7cffc7f89a7')

build() {
  cd "Pleiades-$pkgver"
  cargo build --release --bin pleiades
}

check() {
  cd "Pleiades-$pkgver"
  cargo test --workspace
}

package() {
  cd "Pleiades-$pkgver"
  install -Dm755 target/release/pleiades "$pkgdir/usr/bin/pleiades"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
