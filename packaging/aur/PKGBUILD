pkgname=pleiades
pkgver=1.0.0
pkgrel=1
pkgdesc='Provider-agnostic terminal AI assistant'
arch=('x86_64' 'aarch64')
url='https://github.com/CodWasTaken/Pleiades'
license=('MIT')
makedepends=('cargo')
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('9a1a1b48ff3fda38657e2251910b5aabe4ef9fca1681c3434c492fe379ca9913')

build() {
  cd "Pleiades-$pkgver"
  cargo build --release --bin pleiades
}

check() {
  cd "Pleiades-$pkgver"
  cargo test --workspace
}

package() {
  cd "Pleiades-$pkgver"
  install -Dm755 target/release/pleiades "$pkgdir/usr/bin/pleiades"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
