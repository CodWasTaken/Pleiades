pkgname=pleiades
pkgver=1.1.0
pkgrel=1
pkgdesc='Provider-agnostic terminal AI assistant'
arch=('x86_64' 'aarch64')
url='https://github.com/CodWasTaken/Pleiades'
license=('MIT')
makedepends=('cargo')
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('263154b5bb785ea235c56e2cb7feeb36367de8ec675d27dc9085a8b6488be946')

build() {
  cd "Pleiades-$pkgver"
  cargo build --release --bin pleiades
}

check() {
  cd "Pleiades-$pkgver"
  cargo test --workspace
}

package() {
  cd "Pleiades-$pkgver"
  install -Dm755 target/release/pleiades "$pkgdir/usr/bin/pleiades"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
